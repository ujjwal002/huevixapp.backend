// LingoShorts — Prisma schema
// Design principle: LANGUAGE IS DATA, NOT CODE.
// Every content/user row carries language fields, so adding a new language is a
// config + content change, never a schema rewrite.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum AudioStatus {
  PENDING
  READY
  FAILED
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
  PENDING
}

enum SpeakingSource {
  TRIAL // consumed a free lifetime credit
  AD // consumed a rewarded-ad credit
  SUBSCRIPTION // covered by an active paid plan
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String
  name         String?
  role         Role    @default(USER)

  // Language preferences (the scalability hinge).
  // nativeLanguage  -> language vocab meanings are shown in
  // targetLanguage  -> language the user is learning
  nativeLanguage String @default("hi") // ISO code, e.g. "hi", "en", "es"
  targetLanguage String @default("en")

  // Streak tracking
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime? @db.Date

  // Entitlements
  freeSpeakingCreditsRemaining Int       @default(3) // the "taste" before paywall
  adCreditsRemaining           Int       @default(0) // earned via rewarded ads
  adCreditsGrantedDate         DateTime? @db.Date // for daily ad-credit reset

  adCreditsGrantedToday        Int       @default(0) // credits GRANTED today; the real daily cap, never decremented on spend


  paidSpeakingDate  DateTime? @db.Date
  paidSpeakingCount Int       @default(0)


  notificationsReadAt DateTime?
  savedCards       SavedCard[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription     Subscription?
  refreshTokens    RefreshToken[]
  completions      CardCompletion[]
  speakingAttempts SpeakingAttempt[]
  vocabProgress VocabProgress[]
  startupPromos StartupPromo[]

  deviceTokens DeviceToken[]

  callSecondsBalance   Int       @default(0)
  callSecondsUsedToday Int       @default(0)
  callSecondsDate      DateTime? @db.Date

  vocabTutorSessions VocabTutorSession[]

  callsMade     Call[] @relation("CallsMade")
  callsReceived Call[] @relation("CallsReceived")

  blocksMade      Block[]  @relation("BlocksMade")
  blocksReceived  Block[]  @relation("BlocksReceived")
  reportsMade     Report[] @relation("ReportsMade")
  reportsReceived Report[] @relation("ReportsReceived")

  

  

  @@index([targetLanguage])

  @@index([longestStreak, currentStreak])
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Content — the Inshorts-style cards
// ---------------------------------------------------------------------------

model Card {
  id             String      @id @default(uuid())
  targetLanguage String // language this card teaches, e.g. "en"
  level          Level       @default(BEGINNER)
  topic          String? // e.g. "interview", "daily life", "travel"
  title          String
  body           String // the short text (~60-120 words)
  wordCount      Int         @default(0)
  audioUrl       String? // cached TTS output (listening feature)
  audioStatus    AudioStatus @default(PENDING)
  isPublished    Boolean     @default(false)

  imageUrl       String? // hero image shown at the top of an article card (news feature)
  sourceUrl      String? // original news article link (optional)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Per-native-language glossaries: a single card can carry vocab meanings
  // in many native languages without any schema change.
  vocab       VocabEntry[]
  completions CardCompletion[]
  attempts    SpeakingAttempt[]

  savedBy     SavedCard[]

  @@index([targetLanguage, level, isPublished])
}


model SavedCard {
  id        String   @id @default(uuid())
  userId    String
  cardId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, createdAt])
}

// One row per event (NOT per user). Combined with each user's
// notificationsReadAt timestamp, this gives everyone an unread badge
// without fanning out a row per user.
model Notification {
  id        String   @id @default(uuid())
  type      String   @default("NEW_CARD") // NEW_CARD | ANNOUNCEMENT | ...
  title     String
  body      String?
  cardId    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model VocabEntry {
  id             String  @id @default(uuid())
  cardId         String
  nativeLanguage String // language the meaning is written in, e.g. "hi"
  term           String // the complex word from the card
  partOfSpeech   String?
  meaning        String // definition/translation in nativeLanguage
  example        String?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, nativeLanguage, term])
  @@index([cardId, nativeLanguage])
}

// ---------------------------------------------------------------------------
// Progress
// ---------------------------------------------------------------------------

model CardCompletion {
  id          String   @id @default(uuid())
  userId      String
  cardId      String
  readDone    Boolean  @default(false)
  listenDone  Boolean  @default(false)
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId])
}

model SpeakingAttempt {
  id                String         @id @default(uuid())
  userId            String
  cardId            String
  source            SpeakingSource
  // Scores from the pronunciation assessment (0-100)
  overallScore      Float?
  accuracyScore     Float?
  fluencyScore      Float?
  completenessScore Float?
  prosodyScore      Float?
  transcript        String?
  wordScores        Json? // per-word breakdown for "what you did right/wrong"
  audioUrl          String?
  createdAt         DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

// ---------------------------------------------------------------------------
// Billing
// ---------------------------------------------------------------------------

model Subscription {
  id              String             @id @default(uuid())
  userId          String             @unique
  plan            SubscriptionPlan
  status          SubscriptionStatus @default(PENDING)
  provider        String             @default("razorpay")
  providerOrderId String?
  providerRefId   String? // payment id / subscription id
  currentPeriodEnd DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}


model VocabWord {
  id           String          @id @default(cuid())
  word         String          @unique
  rank         Int
  ladder       Int
  partOfSpeech String?
  meaning      String
  translation  String?
  example      String?
  createdAt    DateTime        @default(now())
  progress     VocabProgress[]

  audioUrl     String? // cached English TTS (word + example), generated once, reused for all users


  @@index([ladder])
}

model VocabProgress {
  id        String    @id @default(cuid())
  userId    String
  wordId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  word      VocabWord @relation(fields: [wordId], references: [id], onDelete: Cascade)
  learnedAt DateTime  @default(now())

  // Spaced-repetition memory state (the "AI knows what you remember" part).
  strength        Int       @default(0) // Leitner box 0..5; higher = remembered longer
  timesTested     Int       @default(0)
  timesCorrect    Int       @default(0)
  consecutiveHits Int       @default(0) // resets to 0 on a miss
  lastTestedAt    DateTime?
  dueAt           DateTime? // next time this word is eligible to be quizzed

  @@unique([userId, wordId])
  @@index([userId, dueAt])
}

model VocabTutorSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  day          DateTime  @db.Date
  state        Json // { phase, quiz[], qi, awaitingRetry, teach[], ti }
  taughtCount  Int       @default(0)
  quizzedCount Int       @default(0)
  correctCount Int       @default(0)
  turns        Int       @default(0) // cost guard: hard cap per session
  endedAt      DateTime?
  createdAt    DateTime  @default(now())

  @@unique([userId, day])
  @@index([userId, createdAt])
}


model GrammarLesson {
  id          String   @id @default(cuid())
  level       String
  order       Int
  title       String   @unique
  summary     String
  explanation String?
  examples    Json?
  tips        Json?
  createdAt   DateTime @default(now())

  @@index([order])
}


model SponsoredCard {
  id         String   @id @default(cuid())
  advertiser String
  title      String
  body       String
  ctaText    String   @default("Learn more")
  ctaUrl     String
  imageUrl   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}


model ProcessedWebhookEvent {
  id        String   @id // provider event id (e.g. Razorpay x-razorpay-event-id)
  eventType String
  createdAt DateTime @default(now())
}


// ----------------------------- Startup promos (paid user ads) -----------------

enum PromoStatus {
  PENDING_PAYMENT // created; awaiting upfront payment
  PENDING_REVIEW  // paid; awaiting admin approval
  ACTIVE          // approved & live (until expiresAt)
  REJECTED        // admin rejected; payment refunded
  EXPIRED         // ran its full duration
}

// A user-created, PAID promotion ("promote your startup"). Distinct from the
// admin-run SponsoredCard house ads: it has an owner, an upfront payment, a
// review step, a per-day live window, and per-viewer impression tracking.
model StartupPromo {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Card content
  startupName String // shown as the advertiser
  title       String // headline
  body        String // short description
  ctaText     String  @default("Visit")
  ctaUrl      String
  imageUrl    String?

  // Purchase
  days              Int         @default(1)
  amountPaise       Int // 299 * days * 100
  status            PromoStatus @default(PENDING_PAYMENT)
  razorpayOrderId   String?
  razorpayPaymentId String?
  refundId          String?
  rejectionReason   String?

  // Live window — starts at APPROVAL (go-live), not at payment
  liveAt    DateTime?
  expiresAt DateTime?

  // Metrics
  clicks      Int               @default(0)
  impressions PromoImpression[] // unique viewers = number of rows

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, expiresAt])
  @@index([ownerId])
}

// One row per (promo, user): impressions count UNIQUE logged-in viewers, not
// repeat scrolls. Guests are not counted.
model PromoImpression {
  id        String       @id @default(cuid())
  promoId   String
  promo     StartupPromo @relation(fields: [promoId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime     @default(now())

  @@unique([promoId, userId])
  @@index([promoId])
}


// App-wide settings (single row, id = "singleton"). Master ad switch + feed
// ad cadence, flippable live from the admin without a redeploy.
model AppSettings {
  id            String   @id @default("singleton")
  adsEnabled    Boolean  @default(false)
  adEveryNCards Int      @default(4)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}


// ---------------------------------------------------------------------------
// Practice calling — 1:1 audio/video "Find People" sessions
// ---------------------------------------------------------------------------

enum CallType {
  AUDIO
  VIDEO
}

enum CallStatus {
  CONNECTING // matched; WebRTC handshake in progress
  ACTIVE     // media negotiated; the two are actually talking
  ENDED      // finished normally (either side hung up / disconnected after ACTIVE)
  MISSED     // matched but never connected (handshake failed / left immediately)
}

// One row per matched practice call. caller = the side that sent the first
// WebRTC offer (the user who was already waiting when the match happened).
model Call {
  id          String     @id @default(uuid())
  callerId    String
  calleeId    String
  type        CallType   @default(VIDEO)
  status      CallStatus @default(CONNECTING)
  startedAt   DateTime   @default(now())
  endedAt     DateTime?
  durationSec Int?

  caller User @relation("CallsMade", fields: [callerId], references: [id], onDelete: Cascade)
  callee User @relation("CallsReceived", fields: [calleeId], references: [id], onDelete: Cascade)

  reports Report[]

  @@index([callerId, startedAt])
  @@index([calleeId, startedAt])
}


// ---------------------------------------------------------------------------
// Safety — blocking + reporting for practice calls
// ---------------------------------------------------------------------------

enum ReportReason {
  HARASSMENT
  SEXUAL_CONTENT
  UNDERAGE
  HATE
  SPAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  ACTIONED
}

// A one-directional block. Enforced BOTH ways at match time (see matchmaking).
model Block {
  id            String   @id @default(uuid())
  userId        String
  blockedUserId String
  createdAt     DateTime @default(now())

  user    User @relation("BlocksMade", fields: [userId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedUserId])
  @@index([blockedUserId])
}

// A user report, optionally tied to the call it happened on. Reporting also
// creates a Block (handled in safety.service.js) so the pair won't rematch.
model Report {
  id             String       @id @default(uuid())
  reporterId     String
  reportedUserId String
  callId         String?
  reason         ReportReason @default(OTHER)
  note           String?
  status         ReportStatus @default(PENDING)
  createdAt      DateTime     @default(now())

  reporter User  @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User  @relation("ReportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)
  call     Call? @relation(fields: [callId], references: [id], onDelete: SetNull)

  @@index([reportedUserId, status])
  @@index([status, createdAt])
}

model DeviceToken {
  id         String   @id @default(uuid())
  token      String   @unique // e.g. "ExponentPushToken[xxxxxxxx]"
  platform   String? // "ios" | "android"
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())

  @@index([userId])
}


model ProcessedPurchase {
  purchaseToken String   @id
  productId     String
  userId        String
  orderId       String?
  grantedAt     DateTime @default(now())

  @@index([userId])
}