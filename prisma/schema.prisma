// Huevix — Prisma schema
// Design principle: LANGUAGE IS DATA, NOT CODE.
// Every content/user row carries language fields, so adding a new language is a
// config + content change, never a schema rewrite.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  USER
  ADMIN
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum AudioStatus {
  PENDING
  READY
  FAILED
}

enum SubscriptionPlan {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  CANCELED
  EXPIRED
  PENDING
}

enum SpeakingSource {
  TRIAL // consumed a free lifetime credit
  AD // consumed a rewarded-ad credit
  SUBSCRIPTION // covered by an active paid plan
}

// ---------------------------------------------------------------------------
// Users
// ---------------------------------------------------------------------------

model User {
  id           String  @id @default(uuid())
  email        String  @unique
  passwordHash String?
  googleId     String? @unique
  emailVerified Boolean @default(false)
  name         String?
  role         Role    @default(USER)

  // Language preferences (the scalability hinge).
  // nativeLanguage  -> language vocab meanings are shown in
  // targetLanguage  -> language the user is learning
  nativeLanguage String @default("hi") // ISO code, e.g. "hi", "en", "es"
  targetLanguage String @default("en")

  // Streak tracking
  currentStreak    Int       @default(0)
  longestStreak    Int       @default(0)
  lastActivityDate DateTime? @db.Date

  // Entitlements
  freeSpeakingCreditsRemaining Int       @default(3) // the "taste" before paywall
  adCreditsRemaining           Int       @default(0) // earned via rewarded ads
  adCreditsGrantedDate         DateTime? @db.Date // for daily ad-credit reset

  adCreditsGrantedToday Int @default(0) // credits GRANTED today; the real daily cap, never decremented on spend

  paidSpeakingDate  DateTime? @db.Date
  paidSpeakingCount Int       @default(0)

  notificationsReadAt DateTime?
  savedCards          SavedCard[]

  eligibilityProfile EligibilityProfile?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscription     Subscription?
  refreshTokens    RefreshToken[]
  completions      CardCompletion[]
  speakingAttempts SpeakingAttempt[]
  vocabProgress    VocabProgress[]
  startupPromos    StartupPromo[]

  quizCurrentStreak  Int       @default(0)
  quizLongestStreak  Int       @default(0)
  quizLastPlayedDate DateTime?

  quizPlays         QuizDailyPlay[]
  quizAnswers       QuizAnswer[]
  quizMonthlyScores QuizMonthlyScore[]
  monthlyWins       MonthlyWinner[]

  deviceTokens DeviceToken[]

  callSecondsBalance   Int       @default(0)
  coinBalance        Int @default(0)
  adCallGrantsToday  Int @default(0)
  callSecondsUsedToday Int       @default(0)
  callSecondsDate      DateTime? @db.Date
  // Video time earned by watching rewarded ads (random VIDEO calls only). Audio
  // is free via freeDailySeconds; tutor is coins-only. Granted by watching an ad
  // (see grantAdCallSeconds), spent by video calls before coins, reset daily
  // alongside callSecondsUsedToday.
  adVideoSecondsRemaining Int @default(0)

  

  vocabTutorSessions VocabTutorSession[]

  callsMade     Call[] @relation("CallsMade")
  callsReceived Call[] @relation("CallsReceived")

  emailTokens   EmailToken[]
  tutorProfile  TutorProfile?
  tutorEarnings TutorEarning[]
  tutorPayouts  TutorPayout[]

  vocabCurrentStreak Int       @default(0)
  vocabLongestStreak Int       @default(0)
  vocabLastPlayedDate DateTime? @db.Date
  vocabPlays         VocabDailyPlay[]
  vocabAnswers       VocabSetAnswer[]

  blocksMade      Block[]  @relation("BlocksMade")
  blocksReceived  Block[]  @relation("BlocksReceived")
  reportsMade     Report[] @relation("ReportsMade")
  reportsReceived Report[] @relation("ReportsReceived")

  referralCode     String?          @unique
  referralsMade    Referral[]       @relation("Referrer")
  referralReceived Referral?        @relation("Referred")
  referralPayouts  ReferralPayout[]

  voiceFreeSecUsed     Int            @default(0)
  voiceFreeSecUsedDate DateTime?
  voiceSessions        VoiceSession[]

  @@index([targetLanguage])
  @@index([longestStreak, currentStreak])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// Content — the Inshorts-style cards
// ---------------------------------------------------------------------------

model Card {
  id             String      @id @default(uuid())
  targetLanguage String // language this card teaches, e.g. "en"
  level          Level       @default(BEGINNER)
  topic          String? // e.g. "interview", "daily life", "travel"
  title          String
  body           String // the short text (~60-120 words)
  keyPoints      String? // 3-5 exam pointers, newline-separated (API returns string[])
  wordCount      Int         @default(0)
  audioUrl       String? // cached TTS output (listening feature)
  audioStatus    AudioStatus @default(PENDING)
  isPublished    Boolean     @default(false)

  imageUrl  String? // hero image shown at the top of an article card (news feature)
  sourceUrl String? // original news article link (optional)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Per-native-language glossaries: a single card can carry vocab meanings
  // in many native languages without any schema change.
  vocab       VocabEntry[]
  completions CardCompletion[]
  attempts    SpeakingAttempt[]

  savedBy SavedCard[]

  @@index([targetLanguage, level, isPublished])
}


model SavedCard {
  id        String   @id @default(uuid())
  userId    String
  cardId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId, createdAt])
  @@index([cardId])
}

// One row per event (NOT per user). Combined with each user's
// notificationsReadAt timestamp, this gives everyone an unread badge
// without fanning out a row per user.
model Notification {
  id        String   @id @default(uuid())
  type      String   @default("NEW_CARD") // NEW_CARD | ANNOUNCEMENT | ...
  title     String
  body      String?
  cardId    String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model VocabEntry {
  id             String  @id @default(uuid())
  cardId         String
  nativeLanguage String // language the meaning is written in, e.g. "hi"
  term           String // the complex word from the card
  partOfSpeech   String?
  meaning        String // definition/translation in nativeLanguage
  example        String?

  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, nativeLanguage, term])
  @@index([cardId, nativeLanguage])
}

// ---------------------------------------------------------------------------
// Progress
// ---------------------------------------------------------------------------

model CardCompletion {
  id          String   @id @default(uuid())
  userId      String
  cardId      String
  readDone    Boolean  @default(false)
  listenDone  Boolean  @default(false)
  completedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([userId, cardId])
  @@index([userId])
  @@index([cardId]) 
}

model SpeakingAttempt {
  id                String         @id @default(uuid())
  userId            String
  cardId            String
  source            SpeakingSource
  // Scores from the pronunciation assessment (0-100)
  overallScore      Float?
  accuracyScore     Float?
  fluencyScore      Float?
  completenessScore Float?
  prosodyScore      Float?
  transcript        String?
  wordScores        Json? // per-word breakdown for "what you did right/wrong"
  audioUrl          String?
  createdAt         DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  card Card @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([cardId])   
}

// ---------------------------------------------------------------------------
// Billing
// ---------------------------------------------------------------------------

model Subscription {
  id               String             @id @default(uuid())
  userId           String             @unique
  plan             SubscriptionPlan
  status           SubscriptionStatus @default(PENDING)
  provider         String             @default("google_play")
  providerOrderId  String?
  // Google Play purchaseToken (or legacy Razorpay payment/subscription id).
  // UNIQUE: a purchase token can only ever be claimed by ONE user's
  // subscription — the DB-level backstop against token sharing/replay
  // ("buy once, activate many accounts"). Nullable uniques allow multiple
  // NULLs in Postgres, so PENDING rows without a token are unaffected.
  providerRefId    String?            @unique
  currentPeriodEnd DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VocabWord {
  id           String          @id @default(cuid())
  word         String          @unique
  rank         Int
  ladder       Int
  partOfSpeech String?
  meaning      String
  translation  String?
  example      String?
  createdAt    DateTime        @default(now())
  progress     VocabProgress[]

  audioUrl String? // cached English TTS (word + example), generated once, reused for all users

  @@index([ladder])
}

model VocabProgress {
  id        String    @id @default(cuid())
  userId    String
  wordId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  word      VocabWord @relation(fields: [wordId], references: [id], onDelete: Cascade)
  learnedAt DateTime  @default(now())

  // Spaced-repetition memory state (the "AI knows what you remember" part).
  strength        Int       @default(0) // Leitner box 0..5; higher = remembered longer
  timesTested     Int       @default(0)
  timesCorrect    Int       @default(0)
  consecutiveHits Int       @default(0) // resets to 0 on a miss
  lastTestedAt    DateTime?
  dueAt           DateTime? // next time this word is eligible to be quizzed

  @@unique([userId, wordId])
  @@index([userId, dueAt])
  @@index([wordId]) 
}

model VocabTutorSession {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  day          DateTime  @db.Date
  state        Json // { phase, quiz[], qi, awaitingRetry, teach[], ti }
  taughtCount  Int       @default(0)
  quizzedCount Int       @default(0)
  correctCount Int       @default(0)
  turns        Int       @default(0) // cost guard: hard cap per session
  endedAt      DateTime?
  createdAt    DateTime  @default(now())

  @@unique([userId, day])
  @@index([userId, createdAt])
}

model GrammarLesson {
  id          String   @id @default(cuid())
  level       String
  order       Int
  title       String   @unique
  summary     String
  explanation String?
  examples    Json?
  tips        Json?
  createdAt   DateTime @default(now())

  @@index([order])
}

model SponsoredCard {
  id         String   @id @default(cuid())
  advertiser String
  title      String
  body       String
  ctaText    String   @default("Learn more")
  ctaUrl     String
  imageUrl   String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model ProcessedWebhookEvent {
  id        String   @id // provider event id (e.g. Razorpay x-razorpay-event-id)
  eventType String
  createdAt DateTime @default(now())
}

// ----------------------------- Startup promos (paid user ads) -----------------

enum PromoStatus {
  PENDING_PAYMENT // created; awaiting upfront payment
  PENDING_REVIEW // paid; awaiting admin approval
  ACTIVE // approved & live (until expiresAt)
  REJECTED // admin rejected; payment refunded
  EXPIRED // ran its full duration
}

// A user-created, PAID promotion ("promote your startup"). Distinct from the
// admin-run SponsoredCard house ads: it has an owner, an upfront payment, a
// review step, a per-day live window, and per-viewer impression tracking.
model StartupPromo {
  id      String @id @default(cuid())
  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  // Card content
  startupName String // shown as the advertiser
  title       String // headline
  body        String // short description
  ctaText     String  @default("Visit")
  ctaUrl      String
  imageUrl    String?

  // Purchase
  days              Int         @default(1)
  amountPaise       Int // 299 * days * 100
  status            PromoStatus @default(PENDING_PAYMENT)
  razorpayOrderId   String?
  razorpayPaymentId String?
  refundId          String?
  rejectionReason   String?

  // Live window — starts at APPROVAL (go-live), not at payment
  liveAt    DateTime?
  expiresAt DateTime?

  // Metrics
  clicks      Int               @default(0)
  impressions PromoImpression[] // unique viewers = number of rows

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, expiresAt])
  @@index([ownerId])
}

// One row per (promo, user): impressions count UNIQUE logged-in viewers, not
// repeat scrolls. Guests are not counted.
model PromoImpression {
  id        String       @id @default(cuid())
  promoId   String
  promo     StartupPromo @relation(fields: [promoId], references: [id], onDelete: Cascade)
  userId    String
  createdAt DateTime     @default(now())

  @@unique([promoId, userId])
  @@index([promoId])
}

// App-wide settings (single row, id = "singleton"). Master ad switch + feed
// ad cadence, flippable live from the admin without a redeploy.
model AppSettings {
  id            String   @id @default("singleton")
  adsEnabled    Boolean  @default(false)
  adEveryNCards Int      @default(4)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ---------------------------------------------------------------------------
// Practice calling — 1:1 audio/video "Find People" sessions
// ---------------------------------------------------------------------------

enum CallType {
  AUDIO
  VIDEO
}

enum CallStatus {
  CONNECTING // matched; WebRTC handshake in progress
  ACTIVE // media negotiated; the two are actually talking
  ENDED // finished normally (either side hung up / disconnected after ACTIVE)
  MISSED // matched but never connected (handshake failed / left immediately)
}

// One row per matched practice call. caller = the side that sent the first
// WebRTC offer (the user who was already waiting when the match happened).
model Call {
  id          String     @id @default(uuid())
  callerId    String
  calleeId    String
  type        CallType   @default(VIDEO)
  kind        String     @default("RANDOM") // RANDOM | TUTOR (callee is the tutor)
  status      CallStatus @default(CONNECTING)
  startedAt   DateTime   @default(now())
  endedAt     DateTime?
  durationSec Int?

  caller User @relation("CallsMade", fields: [callerId], references: [id], onDelete: Cascade)
  callee User @relation("CallsReceived", fields: [calleeId], references: [id], onDelete: Cascade)

  reports Report[]

  @@index([callerId, startedAt])
  @@index([calleeId, startedAt])
}

// ---------------------------------------------------------------------------
// Safety — blocking + reporting for practice calls
// ---------------------------------------------------------------------------

enum ReportReason {
  HARASSMENT
  SEXUAL_CONTENT
  UNDERAGE
  HATE
  SPAM
  OTHER
}

enum ReportStatus {
  PENDING
  REVIEWED
  ACTIONED
}

// A one-directional block. Enforced BOTH ways at match time (see matchmaking).
model Block {
  id            String   @id @default(uuid())
  userId        String
  blockedUserId String
  createdAt     DateTime @default(now())

  user    User @relation("BlocksMade", fields: [userId], references: [id], onDelete: Cascade)
  blocked User @relation("BlocksReceived", fields: [blockedUserId], references: [id], onDelete: Cascade)

  @@unique([userId, blockedUserId])
  @@index([blockedUserId])
}

// A user report, optionally tied to the call it happened on. Reporting also
// creates a Block (handled in safety.service.js) so the pair won't rematch.
model Report {
  id             String       @id @default(uuid())
  reporterId     String
  reportedUserId String
  callId         String?
  reason         ReportReason @default(OTHER)
  note           String?
  status         ReportStatus @default(PENDING)
  createdAt      DateTime     @default(now())

  reporter User  @relation("ReportsMade", fields: [reporterId], references: [id], onDelete: Cascade)
  reported User  @relation("ReportsReceived", fields: [reportedUserId], references: [id], onDelete: Cascade)
  call     Call? @relation(fields: [callId], references: [id], onDelete: SetNull)

  @@index([reportedUserId, status])
  @@index([status, createdAt])
  @@index([reporterId])   // add — User-delete cascade; not covered at all
  @@index([callId])  
}

model DeviceToken {
  id         String   @id @default(uuid())
  token      String   @unique // e.g. "ExponentPushToken[xxxxxxxx]"
  platform   String? // "ios" | "android"
  userId     String?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  lastSeenAt DateTime @default(now())

  @@index([userId])
}

model ProcessedPurchase {
  purchaseToken String   @id
  productId     String
  userId        String
  orderId       String?
  grantedAt     DateTime @default(now())

  @@index([userId])
}

model DailyQuiz {
  id             String   @id @default(uuid())
  date           DateTime
  targetLanguage String   @default("en")
  status         String   @default("READY")
  createdAt      DateTime @default(now())

  questions QuizQuestion[]
  plays     QuizDailyPlay[]

  @@unique([date, targetLanguage])
  @@index([date])
}

model QuizQuestion {
  id           String  @id @default(uuid())
  quizId       String
  order        Int
  prompt       String
  options      Json
  correctIndex Int
  explanation  String?
  voided       Boolean @default(false)

  quiz    DailyQuiz    @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]

  @@unique([quizId, order])
  @@index([quizId])
}

model QuizDailyPlay {
  id            String    @id @default(uuid())
  userId        String
  quizId        String
  startedAt     DateTime  @default(now())
  completedAt   DateTime?
  answeredCount Int       @default(0)
  correctCount  Int       @default(0)
  pointsEarned  Int       @default(0)

  user User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz DailyQuiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  @@unique([userId, quizId])
  @@index([userId])
  @@index([quizId])
}

model QuizAnswer {
  id            String   @id @default(uuid())
  userId        String
  questionId    String
  chosenIndex   Int
  isCorrect     Boolean
  pointsAwarded Int      @default(0)
  answeredAt    DateTime @default(now())

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([userId, questionId])
  @@index([userId, answeredAt])
  @@index([questionId]) 
}

model QuizMonthlyScore {
  id               String   @id @default(uuid())
  userId           String
  period           String
  totalPoints      Int      @default(0)
  correctCount     Int      @default(0)
  lastEarnedAt     DateTime @default(now())
  flaggedForReview Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, period])
  @@index([period, totalPoints])
}

model MonthlyWinner {
  id          String @id @default(uuid())
  period      String @unique
  userId      String
  totalPoints Int
  status      String @default("PENDING_REVIEW")

  contactPhone  String?
  preferredRole String?
  note          String?

  flaggedForReview Boolean   @default(false)
  createdAt        DateTime  @default(now())
  acceptedAt       DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])  
}


// ---------------------------------------------------------------------------
// Email verification + password reset (6-digit OTP, hashed at rest)
// ---------------------------------------------------------------------------

enum EmailTokenType {
  VERIFY_EMAIL
  RESET_PASSWORD
}

model EmailToken {
  id        String         @id @default(uuid())
  userId    String
  type      EmailTokenType
  codeHash  String // sha256(OTP) — the plaintext code is only ever emailed
  expiresAt DateTime
  usedAt    DateTime?
  attempts  Int            @default(0) // wrong guesses; token burns at the cap
  createdAt DateTime       @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
}

// ---------------------------------------------------------------------------
// Tutor marketplace — admin-approved tutors who earn per second of talk time
// ---------------------------------------------------------------------------

enum TutorStatus {
  PENDING // applied, awaiting admin review
  APPROVED // can go online and take calls
  REJECTED
  SUSPENDED // was approved; admin pulled them (bad behaviour etc.)
}

model TutorProfile {
  id              String      @id @default(uuid())
  userId          String      @unique
  bio             String
  languages       String      @default("en") // comma-separated ISO codes
  experience      String?
  upiId           String // where manual payouts are sent
  status          TutorStatus @default(PENDING)
  rejectionReason String?
  isOnline        Boolean     @default(false) // availability toggle (self-serve)
  // What the TUTOR earns, in paise per hour (₹150/hr = 15000). Snapshotted per
  // profile so a future rate change never rewrites past earnings.
  ratePaisePerHour Int        @default(15000)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status, isOnline])
}

// Immutable per-call earnings ledger. unique(callId) makes accrual idempotent:
// a retried endRoom can never pay a tutor twice for the same call.
model TutorEarning {
  id          String   @id @default(uuid())
  tutorUserId String
  callId      String   @unique
  seconds     Int
  amountPaise Int
  createdAt   DateTime @default(now())

  tutor User @relation(fields: [tutorUserId], references: [id], onDelete: Cascade)

  @@index([tutorUserId, createdAt])
}

// Manual payout record: admin pays the UPI, then logs it here. Balance owed =
// sum(TutorEarning.amountPaise) - sum(TutorPayout.amountPaise).
model TutorPayout {
  id          String   @id @default(uuid())
  tutorUserId String
  amountPaise Int
  upiId       String // snapshot of where it was actually sent
  reference   String? // UPI txn id / note
  createdAt   DateTime @default(now())

  tutor User @relation(fields: [tutorUserId], references: [id], onDelete: Cascade)

  @@index([tutorUserId, createdAt])
}

// ===========================================================================
// Daily Vocab Quiz — a separate module from the daily general-knowledge quiz
// and from the existing VocabWord/VocabProgress system. 10 AI-generated words
// per day (learn phase) + one fill-in-the-blank question per word (practice).
// ===========================================================================

model DailyVocabSet {
  id             String   @id @default(uuid())
  date           DateTime
  targetLanguage String   @default("en")
  status         String   @default("READY")
  createdAt      DateTime @default(now())

  words     VocabSetWord[]
  plays     VocabDailyPlay[]

  @@unique([date, targetLanguage])
  @@index([date])
}

model VocabSetWord {
  id           String  @id @default(uuid())
  setId        String
  order        Int
  word         String
  partOfSpeech String?
  meaning      String
  example      String

  // The fill-in-the-blank practice question for this word.
  questionSentence String   // sentence with "___" where the word goes
  options          Json     // 4 options (one is the word)
  correctIndex     Int

  set     DailyVocabSet    @relation(fields: [setId], references: [id], onDelete: Cascade)
  answers VocabSetAnswer[]

  @@unique([setId, order])
  @@index([setId])
}

model VocabSetAnswer {
  id         String   @id @default(cuid())
  userId     String
  wordId     String
  chosenIndex Int
  correct    Boolean
  answeredAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  word VocabSetWord @relation(fields: [wordId], references: [id], onDelete: Cascade)

  @@unique([userId, wordId])
  @@index([userId, answeredAt])
  @@index([wordId])  
}

model VocabDailyPlay {
  id        String   @id @default(cuid())
  userId    String
  setId     String
  correctCount Int    @default(0)
  completedAt  DateTime?
  createdAt DateTime @default(now())

  user User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  set  DailyVocabSet @relation(fields: [setId], references: [id], onDelete: Cascade)

  @@unique([userId, setId])
  @@index([userId])
  @@index([setId])  
}


enum ReferralStatus {
  PENDING   // invited user signed up; hasn't finished the quiz days yet
  QUALIFIED // invited user completed the required quiz days; reward accrued
  FLAGGED   // held for fraud review
  REJECTED  // disqualified
}

model Referral {
  id               String         @id @default(uuid())
  referrerId       String
  referredUserId   String         @unique // each user can be referred only once
  status           ReferralStatus @default(PENDING)
  qualifyingDays   Int            @default(0) // invited user's completed quiz days so far
  qualifiedAt      DateTime?
  rewardPaise      Int            @default(0) // snapshotted when QUALIFIED
  flaggedForReview Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  referrer     User @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredUser User @relation("Referred", fields: [referredUserId], references: [id], onDelete: Cascade)

  @@index([referrerId, status])
}

// Manual UPI payout request, reviewed by an admin (mirrors TutorPayout).
model ReferralPayout {
  id          String   @id @default(uuid())
  userId      String
  amountPaise Int
  count       Int      // number of qualified referrals this payout covers
  upiId       String
  reference   String?  // UPI txn id, filled on PAID
  status      String   @default("PENDING") // PENDING | PAID | REJECTED
  note        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

enum VoiceSessionStatus {
  ACTIVE
  ENDED
}

model VoiceSession {
  id           String             @id @default(uuid())
  userId       String
  status       VoiceSessionStatus @default(ACTIVE)
  turnCount    Int                @default(0)
  userAudioSec Int                @default(0)
  aiAudioSec   Int                @default(0)
  coinsSpent   Int                @default(0)
  startedAt    DateTime           @default(now())
  endedAt      DateTime?

  user  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  turns VoiceTurn[]

  mode      String  @default("general")
  scoreCard Json?

  @@index([userId, startedAt])
}

model VoiceTurn {
  id         String   @id @default(uuid())
  sessionId  String
  userText   String
  aiText     String
  correction String?
  userSec    Int      @default(0)
  aiSec      Int      @default(0)
  coinsSpent Int      @default(0)
  createdAt  DateTime @default(now())

  session VoiceSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
}

// Global TTS phrase cache: a repeated phrase synthesizes once, then serves free.
model VoiceTtsCache {
  hash      String   @id
  url       String
  seconds   Int      @default(1)
  createdAt DateTime @default(now())
}


// ---------------------------------------------------------------------------
// Government Jobs — eligibility & fee engine
// Design principle: RULES ARE DATA, NOT CODE. A job's eligibility criteria and
// fee concessions live as validated JSON on the row; the pure engine in
// src/services/eligibility.service.js evaluates them against a user's
// EligibilityProfile. Adding a new organisation or an odd relaxation pattern
// is a content change, never a schema/code change.
// ---------------------------------------------------------------------------

enum ReservationCategory {
  UR // Unreserved / General
  EWS
  OBC // Central OBC-NCL; also Bihar "BC"
  EBC // Bihar Extremely Backward Class — distinct from OBC, different relaxations
  SC
  ST
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EducationLevel {
  BELOW_TENTH
  TENTH
  ITI // often 12th-equivalent, but only when a notification says so (engine → VERIFY)
  TWELFTH
  DIPLOMA
  GRADUATE
  POST_GRADUATE
  DOCTORATE
}

// One per user, filled once (7 questions), then every job check is instant.
// Kept as a 1:1 satellite instead of columns on User: this vertical is
// optional, and User is already carrying a lot.
model EligibilityProfile {
  userId            String               @id
  dob               DateTime?            @db.Date
  gender            Gender?
  category          ReservationCategory?
  domicileState     String? // "BR", "HR", "UP", … (ISO-style state codes)
  isPwd             Boolean              @default(false)
  isExServiceman    Boolean              @default(false)
  educationLevel    EducationLevel?
  educationSubjects String[]             @default([])
  educationPercent  Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// The source registry — the 25 official recruitment bodies the crawler watches.
model GovJobSource {
  id              String  @id @default(uuid())
  name            String
  shortName       String  @unique // "SSC", "BPSC", "HSSC" — stable key for the crawler
  url             String
  state           String? // null = central / all-India
  crawlEveryHours Int     @default(6)
  requiresCet     Boolean @default(false) // Haryana CET model (HSSC)
  notes           String?
  active          Boolean @default(true)

  jobs      GovJob[]
  createdAt DateTime @default(now())
}

model GovJob {
  id             String  @id @default(uuid())
  sourceId       String?
  title          String // "Bihar Police Constable Recruitment 2026"
  organization   String // "CSBC" — denormalised for display even if sourceId is null
  advtNo         String?
  state          String? // null = all-India
  totalVacancies Int?

  // Status (OPEN/UPCOMING/CLOSED) is DERIVED from these at read time — nothing
  // stored that can go stale. applyEndDate null = "open till further notice".
  applyStartDate DateTime? @db.Date
  applyEndDate   DateTime? @db.Date
  examDate       DateTime? @db.Date

  officialUrl        String?
  notificationPdfUrl String?

  // Validated JSON (shape enforced by src/validators/govJobs.schemas.js):
  // eligibility: { genderAllowed, domicile, education, age{relaxations[]}, extras[] }
  // feeRules:    { currency, default, rules[] (first match wins), coveredBy? }
  eligibility Json
  feeRules    Json

  // Haryana CET: a post-advertisement links to its parent CET cycle.
  requiresCet Boolean @default(false)
  parentJobId String?

  // Human-review gate: crawler/LLM-extracted jobs start unverified; the public
  // list only shows verified rows. One wrong last-date kills user trust.
  verified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  source GovJobSource? @relation(fields: [sourceId], references: [id], onDelete: SetNull)

  @@index([applyEndDate])
  @@index([state, applyEndDate])
  @@index([verified, applyEndDate])
}


// ---------------------------------------------------------------------------
// Government Jobs — crawler bookkeeping
// ---------------------------------------------------------------------------

enum CrawlItemStatus {
  NEW // discovered, not yet extracted
  EXTRACTED // GovJob created (verified:false) — see jobId
  FAILED // fetch/OCR/LLM/validation error — see error
  IGNORED // admin marked as not-a-job (result page, admit card, etc.)
}

model GovCrawlPage {
  sourceId      String    @id
  contentHash   String
  lastCrawledAt DateTime
  lastChangedAt DateTime?
  lastError     String?
}

model GovCrawlItem {
  id       String          @id @default(uuid())
  sourceId String
  url      String
  title    String?
  status   CrawlItemStatus @default(NEW)
  jobId    String?
  error    String?

  firstSeenAt DateTime @default(now())
  lastSeenAt  DateTime

  @@unique([sourceId, url])
  @@index([status, firstSeenAt])
}