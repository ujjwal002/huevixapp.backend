# ----------------------------------------------------------------------------
# LingoShorts backend — environment configuration
# Copy this file to ".env" and fill in values. The app RUNS AS-IS in mock mode
# (no external API keys needed) so you can develop the whole loop locally.
# ----------------------------------------------------------------------------

# --- Core ---
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# --- Database (PostgreSQL) ---
# Example: postgresql://user:password@localhost:5432/lingoshorts?schema=public
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/lingoshorts?schema=public"

# --- Auth / JWT ---
JWT_ACCESS_SECRET=change-me-access-secret
JWT_REFRESH_SECRET=change-me-refresh-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_ROUNDS=10

# --- Freemium / entitlement rules (tune freely) ---
FREE_SPEAKING_TRIAL=3            # lifetime free speaking attempts for new users (the "taste")
PAID_DAILY_SPEAKING_LIMIT=30     # daily cap for paying subscribers (protects your API margins)
MAX_AD_CREDITS_PER_DAY=3         # extra speaking attempts a free user can earn via rewarded ads/day

# --- Pricing (display only; charge via Razorpay) ---
PRICE_MONTHLY_INR=100
PRICE_YEARLY_INR=999

# --- External integrations -------------------------------------------------
# When MOCK_EXTERNAL=true, AI/TTS/Speech/Payments return realistic fake data so
# the backend is fully runnable with zero accounts. Flip to false in production
# and provide the keys below.
MOCK_EXTERNAL=true

# AI content + vocab generation (Anthropic shown; swap provider in ai.service.js)
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-4-6

# Text-to-speech (Azure Cognitive Services Speech)
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia

# Speech / pronunciation assessment (same Azure Speech resource)
# (Uses the AZURE_SPEECH_KEY / AZURE_SPEECH_REGION above.)

# File storage for generated audio + user recordings
# "local" stores under ./storage; switch to s3/gcs in production.
STORAGE_DRIVER=local
STORAGE_PUBLIC_BASE_URL=http://localhost:4000/static

# Payments (Razorpay — standard for India)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# --- CORS ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
