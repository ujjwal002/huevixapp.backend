# ─────────────────────────────────────────────────────────────────────────────
# LingoShorts backend — environment configuration
# Copy to .env: `cp .env.example .env`. Works as-is in mock mode; the only thing
# you MUST set for a real run is DATABASE_URL.
# ─────────────────────────────────────────────────────────────────────────────

# Core
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# Postgres connection string (required to actually run; mock mode still needs a DB)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/lingoshorts?schema=public

# Mock mode: when true (the default outside production) all external providers
# (OpenAI, Azure, Razorpay, ad verification) are stubbed so the app runs with no
# accounts/keys. In production the app REFUSES to boot with this true.
MOCK_EXTERNAL=true

# ── Auth / JWT ───────────────────────────────────────────────────────────────
# In production these MUST be set to long random secrets, or the app won't boot.
#   e.g. node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=30
BCRYPT_ROUNDS=12

# Number of reverse-proxy hops to trust for real client IP (1 for a single
# tunnel/CDN such as cloudflared/ngrok). Needed so per-IP rate limits work.
TRUST_PROXY=1

# Comma-separated allowed CORS origins (the frontend).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Hard deadline (ms) for any single outbound call to a paid/3rd-party API.
EXTERNAL_TIMEOUT_MS=25000

# ── Entitlements / pricing (INR) ─────────────────────────────────────────────
FREE_SPEAKING_TRIAL=3
PAID_DAILY_SPEAKING_LIMIT=30
MAX_AD_CREDITS_PER_DAY=3
PRICE_MONTHLY_INR=100
PRICE_YEARLY_INR=999
PROMO_PER_DAY_INR=299

# ── Rewarded-ad verification ─────────────────────────────────────────────────
# Shared secret used to verify the signed reward token the client forwards after
# an ad. In production with MOCK_EXTERNAL=false the /ads/reward endpoint fails
# CLOSED (grants nothing) if this is unset. See src/services/ad.service.js.
AD_REWARD_SECRET=

# ── AI content generation (OpenAI) ──────────────────────────────────────────
OPENAI_API_KEY=
AI_MODEL=gpt-4o-mini

# ── Speech: TTS + pronunciation assessment (Azure) ───────────────────────────
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=centralindia

# ── Payments (Razorpay) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_PLAN_MONTHLY=

# ── Storage (single switch: local | s3) ──────────────────────────────────────
STORAGE_DRIVER=local
# Public base URL for TTS audio + images (a CloudFront/CDN domain in prod).
STORAGE_PUBLIC_BASE_URL=
# When STORAGE_DRIVER=s3:
S3_BUCKET=
S3_REGION=ap-south-1
# AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# For S3-compatible stores (Cloudflare R2 / MinIO):
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=false

# ── Retention ────────────────────────────────────────────────────────────────
# Used by scripts/prune-recordings.js (delete recordings older than N days).
RETENTION_DAYS=30